{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Dependencies (Backend)",
      "type": "npm",
      "script": "install",
      "path": "backend",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Install Dependencies (Frontend)",
      "type": "npm",
      "script": "install",
      "path": "frontend",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Start Backend Server",
      "type": "npm",
      "script": "start",
      "path": "backend",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "servers"
      }
    },
    {
      "label": "Start Frontend Server",
      "type": "npm",
      "script": "dev",
      "path": "frontend",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "servers"
      }
    },
    {
      "label": "Run Both Servers",
      "dependsOn": [
        "Start Backend Server",
        "Start Frontend Server"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
